# LLM Configuration (shared by inkos & scripts)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o

# Video Model
VIDEO_PROVIDER=seedance
VIDEO_API_KEY=sk-xxx
VIDEO_MODEL=seedance-1.0

# Image Model
IMAGE_PROVIDER=stability
IMAGE_API_KEY=sk-xxx
IMAGE_MODEL=stable-diffusion-xl

# TTS Model (optional)
# TTS_PROVIDER=openai
# TTS_API_KEY=sk-xxx
# TTS_MODEL=tts-1

# Retry Configuration
MAX_RETRIES=2
RETRY_DELAY_SECONDS=5
LLM_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
